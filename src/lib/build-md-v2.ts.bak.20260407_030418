// build-md-v2.ts — 增强版 Markdown 排版引擎 V3
// 核心改进：结构化输出 + 上下文感知展开 + 布局提示
// 专为 Gamma preserve 模式优化

export type SlideItem = {
  id: string;
  title: string;
  content?: string[];
  notes?: string;
  data?: Record<string, string>[];
};

type PageType = 'cover' | 'toc' | 'content' | 'comparison' | 'process' | 'data' | 'quote' | 'ending';

// ========== 上下文感知的要点展开 ==========
const EXPANSION_MAP: Record<string, string> = {
  '创新': '持续创新突破，引领行业变革与升级',
  '高效': '提升运营效率，显著降低时间与成本',
  '专业': '专业团队打造，提供行业领先的高质量服务',
  '安全': '多层安全防护，全面保障数据与隐私安全',
  '用户第一': '以用户需求为核心驱动力，打造极致体验',
  '持续创新': '不断探索前沿技术与创新解决方案',
  '数据驱动': '基于大数据深度分析，科学指导业务决策',
  '智能化': '运用AI与自动化技术，全面提升运营效能',
  '全球化': '布局全球市场，拓展国际化业务版图',
  '可持续发展': '践行ESG理念，推动绿色低碳发展',
  '降本增效': '优化资源配置，实现成本与效率的双重提升',
  '精准营销': '基于用户画像的精细化运营与精准推广',
  '全渠道': '打通线上线下全渠道，构建一体化营销体系',
  '闭环': '构建完整业务闭环，驱动可持续增长',
  '赋能': '以技术赋能业务，推动行业数字化转型升级',
  '协同': '强化团队协同作战，提升跨部门协作效率',
  '敏捷': '采用敏捷方法论，快速响应市场变化与需求',
  '体验': '优化用户全旅程体验，提升满意度与忠诚度',
  '增长': '聚焦核心增长指标，实现规模化可持续增长',
  '生态': '构建开放共赢生态，连接产业链上下游资源',
