# 省事PPT Demo - 环境变量配置
# 复制此文件为 .env.local 并填入实际的API Key

# ===== AI 模型 API Keys =====

# GLM-5-turbo API Key (必需 - 通过 mydamoxing 调用)
MYDAMOXING_API_KEY=your_mydamoxing_api_key_here

# Gamma API Keys (可选 - 用于 Gamma PPT 生成服务)
# 多个 key 用逗号分隔，系统会自动轮换使用
# 获取方式：从 Gamma 官网获取 API Key
# 格式：sk-gamma-xxx1,sk-gamma-xxx2,sk-gamma-xxx3
GAMMA_API_KEYS=your_gamma_api_key_1,your_gamma_api_key_2,your_gamma_api_key_3

# ===== Session 安全配置 =====

# Session Password (生产环境必需)
# 用于加密 Iron Session cookie，必须至少 32 字符
# 生成方式：openssl rand -base64 32
# ⚠️ 警告：不要使用默认密码、弱密码或与示例相同的密码
SESSION_PASSWORD=generate_with_openssl_rand_base64_32_at_least_32_chars

# ===== 数据库配置 =====

# Supabase (必需)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===== 其他配置 =====

# 微信登录 (可选)
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# Debug Token (仅开发环境)
DEBUG_TOKEN=your_debug_token_here

# ===== 安全提示 =====
# 1. 所有包含 API Key 的环境变量不应提交到代码仓库
# 2. .env.local 文件会被 git 忽略，确保敏感信息安全
# 3. 生产环境部署时，在平台（如 Vercel）中配置这些环境变量
# 4. 定期更新 API Key，避免长期使用同一个 Key