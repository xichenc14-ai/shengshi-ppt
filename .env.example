# 省心PPT - 环境变量示例
# 复制为 .env.local 或在 Vercel Project Settings 中配置

# ===== AI Provider Keys =====
# 大纲/智能模式：双路 fallback（DeepSeek + MiniMax）
DEEPSEEK_API_KEY=your_deepseek_api_key
# 可选：多 key 池（逗号分隔），当 DEEPSEEK_API_KEY 为空时取第一个
DEEPSEEK_API_KEYS=your_deepseek_api_key_1,your_deepseek_api_key_2
MINIMAX_API_KEY=your_minimax_api_key

# 可选：控制大纲主模型（deepseek|minimax），默认 deepseek
OUTLINE_PRIMARY_PROVIDER=deepseek

# ===== Gamma =====
# 逗号分隔，支持 key 轮询。可选格式：label:remaining:sk-gamma-xxx:quota_pool_tag:status
# 同 quota_pool_tag 的 key 额度不叠加；不同 quota_pool_tag 的 key 额度叠加。
# status 可为 active/exhausted/disabled/invalid；exhausted/disabled/invalid 不参与轮询。
GAMMA_API_KEYS=主key:1000:sk-gamma_xxx:default:active,备用key:1000:sk-gamma_yyy:default:active

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===== Admin =====
ADMIN_USER_IDS=
ADMIN_USER_PHONES=
# 后台数据库保存 Gamma Key 时必须配置，建议使用 32 字节以上随机字符串
ADMIN_SECRET_ENCRYPTION_KEY=replace_with_long_random_secret
# 仅确认渠道退款参数后开启；未开启时后台退款进入人工处理状态
PAYMENT_AUTO_REFUND_ENABLED=false
