# ===== Core =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SESSION_PASSWORD=replace_with_32_plus_chars
PAYMENT_NOTIFY_URL=https://xinppt.cn/api/payment/xunhu/notify
PAYMENT_RETURN_URL=https://xinppt.cn/account
PAYMENT_NOTIFY_SECRET=replace_with_long_random_secret
ALLOWED_CALLBACK_IPS=127.0.0.1,10.0.0.0/24
PAYMENT_FEATURE_ENABLED=false
NEXT_PUBLIC_PAYMENT_FEATURE_ENABLED=false
PAYMENT_SUPPORTED_METHODS=wechat
NEXT_PUBLIC_PAYMENT_SUPPORTED_METHODS=wechat

# ===== Admin =====
ADMIN_DASHBOARD_KEY=replace_with_admin_key
ADMIN_USER_IDS=
ADMIN_USER_PHONES=

# ===== Payment (XunhuPay / 虎皮椒) =====
XUNHU_PAY_APPID=your_xunhupay_appid
XUNHU_PAY_SECRET=your_xunhupay_secret
# Can be either https://api.xunhupay.com or https://api.xunhupay.com/payment/do.html
XUNHU_PAY_GATEWAY=https://api.xunhupay.com
XUNHU_PAY_PLUGINS=xinppt-next

# ===== Payment (Template mode; legacy fallback) =====
# Available placeholders:
# {provider} {orderNo} {amountFen} {amountYuan} {subject} {userId} {notifyUrl}
PAYMENT_WECHAT_URL_TEMPLATE=
PAYMENT_WECHAT_QRCODE_TEMPLATE=
PAYMENT_ALIPAY_URL_TEMPLATE=
PAYMENT_ALIPAY_QRCODE_TEMPLATE=

# ===== Payment (SDK env mode; use when directly integrating official gateway SDK) =====
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_API_KEY=

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
